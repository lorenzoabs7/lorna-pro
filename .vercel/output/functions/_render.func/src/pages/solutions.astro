---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getI18n } from '../i18n/server';
import type { TranslationKey } from '../i18n/translator';

const solutions = await getCollection('solutions');
const sortedSolutions = solutions.sort((a, b) => (a.data.order || 0) - (b.data.order || 0));

const { t } = getI18n(Astro);

const translateMaybeKey = (value: string | undefined): string => {
  if (!value) return '';
  if (!value.includes('.')) return value;
  return t(value as TranslationKey);
};

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: t('solutionsPage.meta.title'),
  description: t('solutionsPage.meta.description'),
  provider: {
    '@type': 'Organization',
    name: t('common.brandName')
  },
  serviceType: sortedSolutions.map((solution) => translateMaybeKey(solution.data.title)),
  areaServed: 'Worldwide'
};
---

<BaseLayout
  title={t('solutionsPage.meta.title')}
  description={t('solutionsPage.meta.description')}
  structuredData={structuredData}
>
  <section class="bg-gradient-to-br from-brand-primary via-brand-technical-accent-dark to-brand-primary py-20 lg:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-brand-bg-light mb-6 leading-tight">
          {t('solutionsPage.hero.titlePrefix')}
          <span class="text-brand-technical-accent-light">{t('solutionsPage.hero.titleHighlight')}</span>
        </h1>
        <p class="text-xl sm:text-2xl text-brand-text-secondary-dark mb-8 max-w-3xl mx-auto leading-relaxed">
          {t('solutionsPage.hero.description')}
        </p>
      </div>
    </div>
  </section>

  <section class="py-20 bg-brand-bg-light dark:bg-brand-bg-dark">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        {sortedSolutions.map((solution) => (
          <article class="bg-brand-surface-light dark:bg-brand-surface-dark rounded-lg border border-brand-text-secondary-light/20 dark:border-brand-text-secondary-dark/20 hover:border-brand-technical-accent-light transition-all duration-200 hover:shadow-lg overflow-hidden">
            <div class="p-8">
              <div class="mb-6">
                <h2 class="text-2xl font-bold text-brand-text-primary-light dark:text-brand-text-primary-dark mb-3">
                  {translateMaybeKey(solution.data.title)}
                </h2>
                <p class="text-lg text-brand-text-secondary-light dark:text-brand-text-secondary-dark leading-relaxed">
                  {translateMaybeKey(solution.data.description)}
                </p>
              </div>

              <div class="mb-6">
                <h3 class="text-sm font-semibold text-brand-text-primary-light dark:text-brand-text-primary-dark uppercase tracking-wide mb-2">
                  {t('solutionsPage.labels.whoFor')}
                </h3>
                <p class="text-brand-text-secondary-light dark:text-brand-text-secondary-dark text-sm">
                  {translateMaybeKey(solution.data.whoFor)}
                </p>
              </div>

              <div class="mb-6">
                <h3 class="text-sm font-semibold text-brand-text-primary-light dark:text-brand-text-primary-dark uppercase tracking-wide mb-3">
                  {t('solutionsPage.labels.painPoints')}
                </h3>
                <ul class="space-y-2">
                  {solution.data.painPoints.map((pain) => (
                    <li class="flex items-start text-sm text-brand-text-secondary-light dark:text-brand-text-secondary-dark">
                      <svg class="w-4 h-4 text-red-500 mr-2 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                      </svg>
                      {translateMaybeKey(pain)}
                    </li>
                  ))}
                </ul>
              </div>

              <div class="mb-6">
                <h3 class="text-sm font-semibold text-brand-text-primary-light dark:text-brand-text-primary-dark uppercase tracking-wide mb-3">
                  {t('solutionsPage.labels.deliverables')}
                </h3>
                <ul class="space-y-2">
                  {solution.data.deliverables.map((deliverable) => (
                    <li class="flex items-start text-sm text-brand-text-secondary-light dark:text-brand-text-secondary-dark">
                      <svg class="w-4 h-4 text-green-500 mr-2 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                      </svg>
                      {translateMaybeKey(deliverable)}
                    </li>
                  ))}
                </ul>
              </div>

              <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 pt-6 border-t border-brand-text-secondary-light/20 dark:border-brand-text-secondary-dark/20">
                <div class="space-y-1">
                  <div class="text-sm text-brand-text-secondary-light/90 dark:text-brand-text-secondary-dark/90">
                    <span class="font-medium">{t('common.labels.timeline')}:</span> {translateMaybeKey(solution.data.timeline)}
                  </div>
                  <div class="text-sm text-brand-text-secondary-light/90 dark:text-brand-text-secondary-dark/90">
                    <span class="font-medium">{t('common.labels.model')}:</span> {t(`common.engagementModel.${solution.data.engagementModel}`)}
                  </div>
                </div>
                <a
                  href={`/solutions/${solution.slug}`}
                  class="inline-flex items-center px-6 py-3 bg-brand-primary text-brand-bg-light font-semibold rounded-lg hover:bg-brand-technical-accent-dark transition-all duration-200"
                >
                  {translateMaybeKey(solution.data.ctaText || t('common.actions.learnMore'))}
                  <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 bg-brand-primary">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-brand-bg-light mb-6">
        {t('solutionsPage.cta.title')}
      </h2>
      <p class="text-xl text-brand-text-secondary-dark mb-8 leading-relaxed">
        {t('solutionsPage.cta.description')}
      </p>
      <a
        href="/contact"
        class="inline-flex items-center px-8 py-4 bg-brand-technical-accent-light dark:bg-brand-technical-accent-dark text-brand-bg-light font-semibold rounded-lg hover:opacity-90 transition-all duration-200"
      >
        {t('solutionsPage.cta.action')}
        <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
        </svg>
      </a>
    </div>
  </section>
</BaseLayout>
