---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getI18n } from '../i18n/server';

const { t } = getI18n(Astro);

const valueCards = ['execution', 'clarity', 'reliability', 'speed', 'partnership', 'communication'] as const;

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: `${t('navigation.links.about')} ${t('common.brandName')}`,
  description: t('about.meta.description'),
  mainEntity: {
    '@type': 'Organization',
    name: t('common.brandName'),
    description: t('about.meta.description'),
    founder: {
      '@type': 'Person',
      name: 'Lorna'
    },
    knowsAbout: [
      'Software Engineering',
      'Systems Architecture',
      'Automation',
      'Workflow Design',
      'Performance Optimization'
    ]
  }
};
---

<BaseLayout
  title={t('about.meta.title')}
  description={t('about.meta.description')}
  structuredData={structuredData}
>
  <section class="bg-brand-bg-light dark:bg-brand-bg-dark py-20 lg:py-32">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-brand-text-primary-light dark:text-brand-text-primary-dark mb-6 leading-tight">
          {t('about.hero.titlePrefix')}
          <span class="text-brand-primary dark:text-brand-technical-accent-dark">{t('about.hero.titleHighlight')}</span>
        </h1>
        <p class="text-xl sm:text-2xl text-brand-text-secondary-light dark:text-brand-text-secondary-dark mb-8 leading-relaxed">
          {t('about.hero.description')}
        </p>
      </div>
    </div>
  </section>

  <section class="py-20 bg-brand-surface-light dark:bg-brand-surface-dark">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-brand-text-primary-light dark:text-brand-text-primary-dark mb-4">{t('about.story.title')}</h2>
        <p class="text-lg text-brand-text-secondary-light dark:text-brand-text-secondary-dark">
          {t('about.story.subtitle')}
        </p>
      </div>

      <div class="prose prose-lg dark:prose-dark max-w-none">
        <p class="text-xl text-brand-text-primary-light dark:text-brand-text-primary-dark leading-relaxed mb-8">
          {t('about.story.lead')}
        </p>

        <p class="text-brand-text-secondary-light dark:text-brand-text-secondary-dark leading-relaxed mb-8">
          {t('about.story.paragraphs.first')}
        </p>

        <p class="text-brand-text-secondary-light dark:text-brand-text-secondary-dark leading-relaxed mb-8">
          {t('about.story.paragraphs.second')}
        </p>
      </div>
    </div>
  </section>

  <section class="py-20 bg-brand-bg-light dark:bg-brand-bg-dark">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-brand-text-primary-light dark:text-brand-text-primary-dark mb-4">{t('about.values.title')}</h2>
        <p class="text-lg text-brand-text-secondary-light dark:text-brand-text-secondary-dark max-w-2xl mx-auto">
          {t('about.values.subtitle')}
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {valueCards.map((card) => (
          <div class="bg-brand-surface-light dark:bg-brand-surface-dark p-8 rounded-lg border border-brand-text-secondary-light/20 dark:border-brand-text-secondary-dark/20">
            <div class="w-12 h-12 bg-brand-primary/10 dark:bg-brand-primary/20 rounded-lg flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-brand-primary dark:text-brand-technical-accent-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-brand-text-primary-light dark:text-brand-text-primary-dark mb-4">
              {t(`about.values.cards.${card}.title`)}
            </h3>
            <p class="text-brand-text-secondary-light dark:text-brand-text-secondary-dark leading-relaxed">
              {t(`about.values.cards.${card}.description`)}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 bg-brand-surface-light dark:bg-brand-surface-dark border-y border-brand-primary/10 dark:border-brand-primary/20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold text-brand-text-primary-light dark:text-brand-text-primary-dark mb-4">{t('about.approach.title')}</h2>
        <p class="text-lg text-brand-text-secondary-light dark:text-brand-text-secondary-dark">
          {t('about.approach.subtitle')}
        </p>
      </div>

      <div class="space-y-12">
        <div class="flex flex-col lg:flex-row items-center gap-8">
          <div class="lg:w-1/2">
            <h3 class="text-2xl font-bold text-brand-text-primary-light dark:text-brand-text-primary-dark mb-4">{t('about.approach.smallTeam.title')}</h3>
            <p class="text-brand-text-secondary-light dark:text-brand-text-secondary-dark leading-relaxed mb-4">
              {t('about.approach.smallTeam.paragraphs.first')}
            </p>
            <p class="text-brand-text-secondary-light dark:text-brand-text-secondary-dark leading-relaxed">
              {t('about.approach.smallTeam.paragraphs.second')}
            </p>
          </div>
          <div class="lg:w-1/2">
            <div class="bg-brand-bg-light dark:bg-brand-bg-dark rounded-lg p-6 border border-brand-text-secondary-light/20 dark:border-brand-text-secondary-dark/20">
              <div class="space-y-4">
                <div class="flex items-center">
                  <svg class="w-5 h-5 text-brand-positive-signal-light dark:text-brand-positive-signal-dark mr-3" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                  </svg>
                  <span class="text-sm text-brand-text-primary-light dark:text-brand-text-primary-dark">{t('about.approach.smallTeam.checks.first')}</span>
                </div>
                <div class="flex items-center">
                  <svg class="w-5 h-5 text-brand-positive-signal-light dark:text-brand-positive-signal-dark mr-3" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                  </svg>
                  <span class="text-sm text-brand-text-primary-light dark:text-brand-text-primary-dark">{t('about.approach.smallTeam.checks.second')}</span>
                </div>
                <div class="flex items-center">
                  <svg class="w-5 h-5 text-brand-positive-signal-light dark:text-brand-positive-signal-dark mr-3" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                  </svg>
                  <span class="text-sm text-brand-text-primary-light dark:text-brand-text-primary-dark">{t('about.approach.smallTeam.checks.third')}</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="flex flex-col lg:flex-row-reverse items-center gap-8">
          <div class="lg:w-1/2">
            <h3 class="text-2xl font-bold text-brand-text-primary-light dark:text-brand-text-primary-dark mb-4">{t('about.approach.collaboration.title')}</h3>
            <p class="text-brand-text-secondary-light dark:text-brand-text-secondary-dark leading-relaxed mb-4">
              {t('about.approach.collaboration.paragraphs.first')}
            </p>
            <p class="text-brand-text-secondary-light dark:text-brand-text-secondary-dark leading-relaxed">
              {t('about.approach.collaboration.paragraphs.second')}
            </p>
          </div>
          <div class="lg:w-1/2">
            <div class="bg-brand-bg-light dark:bg-brand-bg-dark rounded-lg p-6 border border-brand-text-secondary-light/20 dark:border-brand-text-secondary-dark/20">
              <div class="space-y-4">
                <div class="flex items-center">
                  <svg class="w-5 h-5 text-brand-positive-signal-light dark:text-brand-positive-signal-dark mr-3" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                  </svg>
                  <span class="text-sm text-brand-text-primary-light dark:text-brand-text-primary-dark">{t('about.approach.collaboration.checks.first')}</span>
                </div>
                <div class="flex items-center">
                  <svg class="w-5 h-5 text-brand-positive-signal-light dark:text-brand-positive-signal-dark mr-3" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                  </svg>
                  <span class="text-sm text-brand-text-primary-light dark:text-brand-text-primary-dark">{t('about.approach.collaboration.checks.second')}</span>
                </div>
                <div class="flex items-center">
                  <svg class="w-5 h-5 text-brand-positive-signal-light dark:text-brand-positive-signal-dark mr-3" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                  </svg>
                  <span class="text-sm text-brand-text-primary-light dark:text-brand-text-primary-dark">{t('about.approach.collaboration.checks.third')}</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-brand-bg-light dark:bg-brand-bg-dark border-t border-brand-primary/15 dark:border-brand-primary/20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-brand-text-primary-light dark:text-brand-text-primary-dark mb-6">
        {t('about.cta.title')}
      </h2>
      <p class="text-xl text-brand-text-secondary-light dark:text-brand-text-secondary-dark mb-8 leading-relaxed">
        {t('about.cta.description')}
      </p>
      <a
        href="/contact"
        class="inline-flex items-center px-8 py-4 bg-brand-primary text-brand-bg-light font-semibold rounded-lg hover:bg-brand-primary/90 transition-all duration-200"
      >
        {t('about.cta.action')}
        <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
        </svg>
      </a>
    </div>
  </section>
</BaseLayout>
