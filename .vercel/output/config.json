{
	"version": 3,
	"routes": [
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "^\\/_image$",
			"dest": "_render"
		},
		{
			"src": "^\\/about\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/api\\/contact\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/contact\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/privacy\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/sitemap\\.xml\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/solutions\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/solutions(?:\\/(.*?))?\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/store\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/terms\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/work\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/work(?:\\/(.*?))?\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/$",
			"dest": "_render"
		}
	]
}