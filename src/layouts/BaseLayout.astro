---
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import { ViewTransitions } from 'astro:transitions';
import '../styles/global.css';
import { getI18n } from '../i18n/server';
import { LOCALE_COOKIE_NAME, LOCALE_STORAGE_KEY } from '../i18n/locales';
import {
  SITE_NAME,
  TWITTER_HANDLE,
  DEFAULT_ROBOTS,
  absoluteImageUrl
} from '../lib/seo';

export interface Props {
  /** Page <title> and og:title / twitter:title */
  title: string;
  /** Meta description, og:description, twitter:description */
  description: string;
  /**
   * Relative path or absolute URL for the share image.
   * Must be at least 1200×630 for optimal social sharing.
   * Defaults to /og-image.png.
   */
  image?: string;
  /**
   * Explicit canonical URL. Defaults to Astro.site + Astro.url.pathname.
   * Pass a full URL string when the canonical differs from the current path.
   */
  canonical?: string;
  /** JSON-LD structured data object or array of objects. */
  structuredData?: object | object[];
  /**
   * Open Graph type. Use 'article' for case studies and blog posts.
   * Defaults to 'website'.
   */
  ogType?: 'website' | 'article';
  /**
   * Robots meta tag. Defaults to 'index, follow'.
   * Use 'noindex, follow' for legal/utility pages.
   */
  robots?: string;
  /** ISO 8601 date string — sets article:published_time when ogType is 'article'. */
  datePublished?: string;
  /** ISO 8601 date string — sets article:modified_time when ogType is 'article'. */
  dateModified?: string;
}

const {
  title,
  description,
  image = '/og-image.png',
  canonical,
  structuredData,
  ogType = 'website',
  robots = DEFAULT_ROBOTS,
  datePublished,
  dateModified
} = Astro.props;

const canonicalHref =
  canonical ?? new URL(Astro.url.pathname, Astro.site).toString();

const ogImage = absoluteImageUrl(image);

const currentPath = Astro.url.pathname;
const { locale } = getI18n(Astro);
---

<!doctype html>
<html lang={locale} data-locale={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonicalHref} />

    <!--
      Favicon chain (order matters):
      1. favicon.ico  — legacy browsers, bots, email clients
      2. favicon.svg  — modern browsers (sharp at any size, supports dark mode)
      3. apple-touch-icon — iOS home screen
      4. site.webmanifest — PWA manifest (also registers icons for Android)

      Run `pnpm generate:assets` to regenerate favicon.ico and apple-touch-icon.png.
    -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#ffffff" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#0f172a" />

    <!-- Open Graph -->
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalHref} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta property="og:locale" content="en_US" />
    {ogType === 'article' && datePublished && (
      <meta property="article:published_time" content={datePublished} />
    )}
    {ogType === 'article' && dateModified && (
      <meta property="article:modified_time" content={dateModified} />
    )}
    {ogType === 'article' && (
      <meta property="article:author" content={SITE_NAME} />
    )}

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={TWITTER_HANDLE} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={title} />

    <!-- JSON-LD Structured Data -->
    {structuredData && (
      <script
        is:inline
        type="application/ld+json"
        set:html={JSON.stringify(structuredData)}
      />
    )}

    <ViewTransitions />

    <!--
      Inline locale detection — runs before first paint to avoid flash of wrong lang attribute.
      Reads cookie → localStorage → navigator.languages → fallback 'en'.
    -->
    <script is:inline define:vars={{ localeCookieName: LOCALE_COOKIE_NAME, localeStorageKey: LOCALE_STORAGE_KEY }}>
      (function() {
        var supported = ['en', 'es', 'it', 'de', 'ru', 'zh'];
        var fallback = 'en';
        var oneYear = 60 * 60 * 24 * 365;

        function normalize(value) {
          if (!value || typeof value !== 'string') return null;
          var normalized = value.toLowerCase().trim().replace('_', '-');
          if (supported.indexOf(normalized) !== -1) return normalized;
          var base = normalized.split('-')[0];
          return supported.indexOf(base) !== -1 ? base : null;
        }

        function readCookie(name) {
          var match = document.cookie.match(new RegExp('(?:^|; )' + name + '=([^;]*)'));
          return match ? decodeURIComponent(match[1]) : null;
        }

        function detectBrowserLocale() {
          var candidates = Array.isArray(navigator.languages) && navigator.languages.length
            ? navigator.languages
            : [navigator.language];
          for (var i = 0; i < candidates.length; i += 1) {
            var loc = normalize(candidates[i]);
            if (loc) return loc;
          }
          return null;
        }

        var cookieLocale = normalize(readCookie(localeCookieName));
        var storedLocale = null;
        try {
          storedLocale = normalize(localStorage.getItem(localeStorageKey));
        } catch (_e) {
          storedLocale = null;
        }

        var locale = cookieLocale || storedLocale || detectBrowserLocale() || fallback;
        document.documentElement.lang = locale;
        document.documentElement.dataset.locale = locale;
        window.__LORNA_LOCALE__ = locale;
        document.cookie = localeCookieName + '=' + encodeURIComponent(locale) + '; path=/; max-age=' + oneYear + '; SameSite=Lax';
        try {
          localStorage.setItem(localeStorageKey, locale);
        } catch (_e) {}
      })();
    </script>

    <!-- Inline dark-mode detection — prevents flash of wrong theme -->
    <script is:inline>
      (function() {
        var s = localStorage.getItem('theme');
        var p = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (s === 'dark' || (s !== 'light' && p)) {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      })();
    </script>
  </head>

  <body class="bg-brand-bg-light dark:bg-brand-bg-dark text-brand-text-primary-light dark:text-brand-text-primary-dark font-sans antialiased">
    <Navigation currentPath={currentPath} />

    <main id="main-content" role="main">
      <slot />
    </main>

    <Footer />

    <!-- Analytics: only active on the production hostname -->
    <script>
      if (typeof window !== 'undefined' && window.location.hostname === 'lornadev.com') {
        const script = document.createElement('script');
        script.src = 'https://plausible.io/js/script.js';
        script.defer = true;
        script.setAttribute('data-domain', 'lornadev.com');
        document.head.appendChild(script);
      }
    </script>

    <style is:global>
      html {
        scroll-behavior: smooth;
      }

      a:focus,
      button:focus,
      input:focus,
      textarea:focus,
      select:focus {
        outline: 2px solid var(--brand-focus);
        outline-offset: 2px;
      }

      :root:not(.dark) { --brand-focus: #3A6EA5; }
      .dark { --brand-focus: #4A82BC; }

      .js-focus-visible :focus:not(.focus-visible) {
        outline: none;
      }

      .loading {
        opacity: 0.6;
        pointer-events: none;
      }
    </style>
  </body>
</html>
