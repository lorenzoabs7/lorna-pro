---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getI18n } from '../i18n/server';

interface ContentBlock {
  type: 'subheading' | 'paragraph' | 'list' | 'ordered';
  text?: string;
  items?: string[];
}

interface ContentSection {
  heading: string;
  blocks: ContentBlock[];
}

const { t, raw } = getI18n(Astro);

const sections = raw<ContentSection[]>('terms.sections') ?? [];

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: t('terms.title'),
  description: t('terms.meta.description'),
  mainEntity: {
    '@type': 'Organization',
    name: t('common.brandName')
  }
};
---

<BaseLayout
  title={t('terms.meta.title')}
  description={t('terms.meta.description')}
  structuredData={structuredData}
>
  <section class="py-20 bg-brand-bg-light dark:bg-brand-bg-dark">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <h1 class="text-4xl font-bold text-brand-text-primary-light dark:text-brand-text-primary-dark mb-4">{t('terms.title')}</h1>
        <p class="text-lg text-brand-text-secondary-light dark:text-brand-text-secondary-dark">
          {t('terms.lastUpdated')}
        </p>
      </div>

      <div class="prose prose-lg max-w-none">
        <p class="lead">
          {t('terms.lead')}
        </p>

        {sections.map((section) => (
          <>
            <h2>{section.heading}</h2>
            {section.blocks.map((block) => (
              <>
                {block.type === 'subheading' && block.text && <h3>{block.text}</h3>}
                {block.type === 'paragraph' && block.text && <p>{block.text}</p>}
                {block.type === 'list' && block.items && (
                  <ul>
                    {block.items.map((item) => <li>{item}</li>)}
                  </ul>
                )}
                {block.type === 'ordered' && block.items && (
                  <ol>
                    {block.items.map((item) => <li>{item}</li>)}
                  </ol>
                )}
              </>
            ))}
          </>
        ))}

        <div class="bg-brand-surface-light dark:bg-brand-surface-dark p-6 rounded-lg mt-6">
          <p class="mb-2"><strong>{t('terms.contactCard.emailLabel')}</strong> {t('terms.contactCard.email')}</p>
          <p><strong>{t('terms.contactCard.responseTimeLabel')}</strong> {t('terms.contactCard.responseTime')}</p>
        </div>

        <h2>{t('terms.acceptance.heading')}</h2>

        <p class="text-sm text-brand-text-secondary-light dark:text-brand-text-secondary-dark bg-brand-critical-emphasis/10 dark:bg-brand-critical-emphasis/20 p-4 rounded-lg border border-brand-critical-emphasis/25">
          <strong>{t('terms.acceptance.title')}</strong> {t('terms.acceptance.text')}
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
