{
  "name": "lorna-dev",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "generate:assets": "node scripts/generate-og-image.mjs && node scripts/generate-favicon.mjs",
    "deploy": "pnpm build && node scripts/deploy-s3.mjs",
    "dev": "node scripts/generate-og-image.mjs && node scripts/generate-favicon.mjs && pnpm exec astro dev",
    "start": "pnpm exec astro dev",
    "prebuild": "node scripts/generate-og-image.mjs && node scripts/generate-favicon.mjs",
    "build": "pnpm exec astro build",
    "check": "pnpm exec astro check",
    "preview": "pnpm exec astro preview",
    "astro": "astro",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx,.astro",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx,.astro --fix",
    "format": "prettier --write .",
    "reinstall": "rm -rf node_modules && pnpm install"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/mdx": "^3.1.7",
    "@astrojs/react": "^3.6.2",
    "@astrojs/rss": "^4.0.7",
    "@astrojs/sitemap": "^3.1.6",
    "@astrojs/tailwind": "^5.1.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/better-sqlite3": "^7.6.11",
    "@types/react": "^18.3.8",
    "@types/react-dom": "^18.3.0",
    "astro": "^4.16.6",
    "better-sqlite3": "^11.3.0",
    "lucide-react": "^0.439.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^4.0.0",
    "tailwindcss": "^3.4.10",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@astrojs/ts-plugin": "^1.10.3",
    "sharp": "^0.33.5",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "eslint": "^9.12.0",
    "eslint-plugin-astro": "^1.2.4",
    "prettier": "^3.3.3",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.9.3"
  }
}
